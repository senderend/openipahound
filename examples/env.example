# FreeIPA target. Use a hostname or IP address for password auth.
# Kerberos auth should use a hostname that resolves through DNS or /etc/hosts.
IPA_SERVER=ipa.example.test
# IPA_SERVER=10.0.0.10
IPA_DOMAIN=example.test

# Optional simple LDAP bind settings for repeatable/non-interactive runs.
# For an interactive first run, prefer:
# openipahound collect ipa.example.test -d example.test -u openipahound-reader -p -o ./out
IPA_CREDENTIAL_PROFILE=collector
IPA_COLLECTOR_USER=openipahound-reader
# IPA_COLLECTOR_PASSWORD=change-me

# Or use an admin profile for the most complete collection
# IPA_CREDENTIAL_PROFILE=admin
# IPA_ADMIN_USER=admin
# IPA_ADMIN_PASSWORD=change-me

# Or use Kerberos with an existing ticket cache instead of LDAP bind credentials
# IPA_AUTH=kerberos

# Optional
# IPA_BASE_DN=dc=example,dc=test
